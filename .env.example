# Copy to .env and set secure values for production
ADMIN_API_KEY=please-set-a-secure-random-value
PORT=3000
DATABASE_URL=postgresql://vela:vela-pass@localhost:5432/vela
# ─── Vela Environment Variables ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is in .gitignore.

# ─── Ollama ───────────────────────────────────────────────────────────────────
# Local Ollama server URL. Default works for standard Ollama installations.
VITE_OLLAMA_BASE_URL=http://localhost:11434

# Chat model — optimised for 8GB RAM systems.
# Change to llama3.1:70b on a GPU server for production.
VITE_OLLAMA_CHAT_MODEL=llama3.2:3b

# Embedding model — for long-term memory retrieval
VITE_OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── Cloud Proxy (optional) ─────────────────────────────────────────────────
# Start the local proxy with: npm run start:server
# Set AI_PROVIDER to groq/openai/together for hosted inference.
AI_PROVIDER=ollama
PORT=3000
OLLAMA_BASE_URL=http://localhost:11434
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
TOGETHER_BASE_URL=https://api.together.xyz/v1
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo

# ─── Supabase (Phase 2 — optional for MVP) ───────────────────────────────────
# MVP stores everything in Chrome local storage (no Supabase needed).
# Add Supabase in Phase 2 for cross-device sync and team accounts.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Set to 'true' to enable experimental features
VITE_ENABLE_SUPABASE_SYNC=false
VITE_ENABLE_GOOGLE_OAUTH=false
VITE_ENABLE_WHATSAPP_INTEGRATION=false

# ─── Environment ──────────────────────────────────────────────────────────────
NODE_ENV=development

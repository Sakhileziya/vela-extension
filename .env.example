# ─── Vela Environment Variables ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is in .gitignore.

# ─── Ollama ───────────────────────────────────────────────────────────────────
# Local Ollama server URL. Default works for standard Ollama installations.
VITE_OLLAMA_BASE_URL=http://localhost:11434

# Chat model — optimised for 8GB RAM systems.
# Change to llama3.1:70b on a GPU server for production.
VITE_OLLAMA_CHAT_MODEL=llama3.2:3b

# Embedding model — for long-term memory retrieval
VITE_OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── Supabase (Phase 2 — optional for MVP) ───────────────────────────────────
# MVP stores everything in Chrome local storage (no Supabase needed).
# Add Supabase in Phase 2 for cross-device sync and team accounts.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Set to 'true' to enable experimental features
VITE_ENABLE_SUPABASE_SYNC=false
VITE_ENABLE_GOOGLE_OAUTH=false
VITE_ENABLE_WHATSAPP_INTEGRATION=false

# ─── Environment ──────────────────────────────────────────────────────────────
NODE_ENV=development
